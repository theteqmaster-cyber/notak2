APP_NAME=Notak2
APP_ENV=production
APP_KEY=              # Run: php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
DB_CONNECTION=pgsql
# Option A — Full connection string (recommended):
DB_URL=              # postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Option B — Individual fields:
DB_HOST=             # db.YOURPROJECTREF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=         # Your Supabase DB password
DB_SSLMODE=require

# ─── Session / Cache / Queue (all stored in DB — ephemeral-safe) ─────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Cloudflare R2 File Storage ───────────────────────────────────────────────
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=       # R2 Access Key ID
AWS_SECRET_ACCESS_KEY=   # R2 Secret Access Key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=              # R2 bucket name (e.g. notak2-files)
AWS_ENDPOINT=            # https://ACCOUNTID.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@notak2.onrender.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
