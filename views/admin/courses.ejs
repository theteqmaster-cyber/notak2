<%- include('../layouts/app', { title, body: `
<div class="page-header"><h1>Courses</h1></div>

<% if (activeSemester) { %>
<div class="card" style="margin-bottom:24px;">
  <div class="card-header"><span class="card-title">Add Course to <em><%= activeSemester.name %></em></span></div>
  <div class="card-body">
    <form method="POST" action="/admin/courses" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
      <input type="hidden" name="semester_id" value="<%= activeSemester.id %>">
      <div class="form-group" style="margin:0;flex:1;min-width:160px;"><label class="form-label">Course Name *</label><input type="text" name="name" class="form-control" placeholder="e.g. Mathematics 101" required></div>
      <div class="form-group" style="margin:0;min-width:100px;"><label class="form-label">Code</label><input type="text" name="code" class="form-control" placeholder="MATH101"></div>
      <div class="form-group" style="margin:0;"><label class="form-label">Color</label><input type="color" name="color" class="form-control" value="#4F6EF7" style="padding:2px;height:38px;width:52px;"></div>
      <button type="submit" class="btn btn-primary"><%- icon('plus') %> Add</button>
    </form>
  </div>
</div>
<% } %>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead><tr><th>Name</th><th>Code</th><th>Semester</th><th>Items</th><th></th></tr></thead>
      <tbody>
        <% courses.forEach(c => { %>
        <tr>
          <td><div style="display:flex;align-items:center;gap:8px;"><div style="width:10px;height:10px;border-radius:50%;background:<%= c.color||'#4F6EF7' %>;flex-shrink:0;"></div><strong><%= c.name %></strong></div></td>
          <td style="font-size:12px;color:var(--text-3);"><%= c.code||'—' %></td>
          <td style="font-size:13px;color:var(--text-2);"><%= c.semester_name %></td>
          <td><%= c.item_count %></td>
          <td>
            <form method="POST" action="/admin/courses/<%= c.id %>/delete" style="display:inline;">
              <button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="return confirm('Delete <%= c.name %> and all its items?')"><%- icon('trash-2') %></button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
` }) %>
