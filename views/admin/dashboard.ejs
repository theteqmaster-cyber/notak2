<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>Admin — Notak2</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
<div class="admin-shell">

  <header class="admin-header">
    <div class="admin-brand">
      <span class="brand-hex">⬡</span>
      <span class="brand-text">Notak2 <em>Admin</em></span>
    </div>
    <div class="admin-header-right">
      <span class="admin-user-pill"><%= user.name %></span>
      <a href="/logout" class="admin-logout-btn">Sign Out</a>
    </div>
  </header>

  <main class="admin-main">

    <% if (flash) { %>
    <div class="flash flash-<%= flash.type %>"><%= flash.message %></div>
    <% } %>

    <!-- Stats row -->
    <div class="stats-row" id="admin-stats-row">
      <div class="stat-card"><div class="stat-val" id="stat-users">—</div><div class="stat-lbl">Users</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-devices">—</div><div class="stat-lbl">Devices</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-notes">—</div><div class="stat-lbl">Notes</div></div>
      <div class="stat-card"><div class="stat-val" id="stat-files">—</div><div class="stat-lbl">Files</div></div>
    </div>

    <!-- Users -->
    <section class="admin-section">
      <h2 class="section-title">Accounts (<%= users.length %>)</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
          <tbody>
          <% for (const u of users) { %>
          <tr class="<%= !u.is_active ? 'row-inactive' : '' %>">
            <td><strong><%= u.name %></strong></td>
            <td><%= u.email %></td>
            <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
            <td><span class="status-dot <%= u.is_active ? 'active' : 'inactive' %>"></span> <%= u.is_active ? 'Active' : 'Inactive' %></td>
            <td class="muted"><%= new Date(u.created_at).toLocaleDateString() %></td>
            <td class="actions">
              <% if (!['admin','ci'].includes(u.role)) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/toggle" style="display:inline">
                <button class="action-btn <%= u.is_active ? 'warn' : 'ok' %>" title="<%= u.is_active ? 'Deactivate' : 'Activate' %>">
                  <%= u.is_active ? '⏸' : '▶' %>
                </button>
              </form>
              <button class="action-btn danger" onclick="openResetModal(<%= u.id %>)" title="Reset password">🔑</button>
              <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline"
                    onsubmit="return confirm('Delete <%= u.name %>? This cannot be undone.')">
                <button class="action-btn danger" title="Delete">🗑</button>
              </form>
              <% } else { %>
              <span class="muted" style="font-size:12px">Protected</span>
              <% } %>
            </td>
          </tr>
          <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Devices -->
    <section class="admin-section">
      <h2 class="section-title">Registered Devices (<%= devices.length %>)</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>Device Name</th><th>Platform</th><th>User</th><th>Last Seen</th><th>Actions</th></tr></thead>
          <tbody>
          <% for (const d of devices) { %>
          <tr>
            <td><strong><%= d.name %></strong></td>
            <td><span class="platform-badge"><%= d.platform || '—' %></span></td>
            <td class="muted"><%= d.email || '—' %></td>
            <td class="muted"><%= d.last_seen ? new Date(d.last_seen).toLocaleString() : '—' %></td>
            <td>
              <form method="POST" action="/admin/devices/<%= d.id %>/remove" style="display:inline"
                    onsubmit="return confirm('Remove this device?')">
                <button class="action-btn danger" title="Remove device">🗑</button>
              </form>
            </td>
          </tr>
          <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Activity Log -->
    <section class="admin-section">
      <h2 class="section-title">Recent Activity</h2>
      <div class="table-wrap">
        <table class="admin-table">
          <thead><tr><th>Time</th><th>User</th><th>Event</th><th>IP</th><th>Flagged</th></tr></thead>
          <tbody>
          <% for (const l of logs) { %>
          <tr class="<%= l.is_flagged ? 'row-flagged' : '' %>">
            <td class="muted" style="white-space:nowrap;"><%= new Date(l.created_at).toLocaleString() %></td>
            <td><%= l.email || 'system' %></td>
            <td><code class="event-code"><%= l.event_type %></code></td>
            <td class="muted"><%= l.ip_address || '—' %></td>
            <td><% if (l.is_flagged) { %><span class="flag-badge">⚑</span><% } %></td>
          </tr>
          <% } %>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</div>

<!-- Reset password modal -->
<div id="reset-modal" class="modal hidden">
  <div class="modal-box">
    <h3>Reset Password</h3>
    <form method="POST" id="reset-form">
      <div class="form-group" style="margin:16px 0;">
        <label>New Password (min 8 chars)</label>
        <input type="password" name="new_password" minlength="8" required placeholder="New password">
      </div>
      <div class="modal-actions">
        <button type="button" onclick="closeResetModal()" class="action-btn">Cancel</button>
        <button type="submit" class="action-btn ok">Reset</button>
      </div>
    </form>
  </div>
</div>

<script>
async function loadStats() {
  const r = await fetch('/admin/api/stats');
  const d = await r.json();
  document.getElementById('stat-users').textContent   = d.users;
  document.getElementById('stat-devices').textContent = d.devices;
  document.getElementById('stat-notes').textContent   = d.notes;
  document.getElementById('stat-files').textContent   = d.files;
}
loadStats();

function openResetModal(userId) {
  document.getElementById('reset-form').action = `/admin/users/${userId}/reset-password`;
  document.getElementById('reset-modal').classList.remove('hidden');
}
function closeResetModal() {
  document.getElementById('reset-modal').classList.add('hidden');
}
document.getElementById('reset-modal').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeResetModal();
});
</script>
</body>
</html>
