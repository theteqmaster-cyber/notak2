<%- include('../layouts/app', { title, body: `
<div class="page-header">
  <h1>All Items</h1>
  <a href="/admin/upload" class="btn btn-primary btn-sm"><%- icon('upload') %> Upload</a>
</div>

<form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;align-items:flex-end;">
  <div class="form-group" style="margin:0;min-width:150px;">
    <label class="form-label">Type</label>
    <select name="type" class="form-control">
      <option value="">All Types</option>
      <% [['N','Notes'],['A','Assignments'],['P','Presentations'],['T','Tests'],['S','Sources']].forEach(([t,l]) => { %>
      <option value="<%= t %>" <%= filters.type===t?'selected':'' %>><%= l %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group" style="margin:0;min-width:180px;">
    <label class="form-label">Search</label>
    <input type="text" name="search" class="form-control" placeholder="Title…" value="<%= filters.search||'' %>">
  </div>
  <button type="submit" class="btn btn-primary btn-sm"><%- icon('search') %> Filter</button>
  <% if (filters.type||filters.search) { %><a href="/admin/items" class="btn btn-ghost btn-sm">Clear</a><% } %>
</form>

<div class="card">
  <% if (!items.length) { %>
  <div class="empty-state"><%- icon('files') %><h3>No items found</h3><p><a href="/admin/upload">Upload something</a></p></div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Type</th><th>Title</th><th>Course</th><th>Size</th><th>Downloads</th><th>Date</th><th></th></tr></thead>
      <tbody>
        <% items.forEach(item => { %>
        <tr>
          <td><span class="badge badge-<%= item.type %>"><%= TYPE_LABELS[item.type] %></span></td>
          <td><a href="/item/<%= item.id %>" style="font-weight:500;color:var(--text-1);text-decoration:none;"><%= item.title %></a></td>
          <td style="font-size:12px;color:var(--text-2);"><%= item.course_name %></td>
          <td style="font-size:12px;color:var(--text-3);"><%= item.file_size ? (item.file_size/1048576).toFixed(1)+' MB' : '—' %></td>
          <td style="font-size:13px;text-align:center;"><%= item.download_count %></td>
          <td style="font-size:12px;color:var(--text-3);white-space:nowrap;"><%= new Date(item.created_at).toLocaleDateString() %></td>
          <td>
            <form method="POST" action="/admin/items/<%= item.id %>/delete" style="display:inline;">
              <button class="btn btn-ghost btn-sm" style="color:var(--danger);" onclick="return confirm('Delete \\'<%= item.title.replace(/'/g,\\'\\\\\\'\\'') %>\\'?')"><%- icon('trash-2') %></button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
` }) %>
