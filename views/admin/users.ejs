<%- include('../layouts/app_header', { title }) %>
<div class="page-header"><h1>Users</h1></div>
<div class="card">
  <div class="table-wrap">
    <table>
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Joined</th><th></th></tr></thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td><div style="display:flex;align-items:center;gap:8px;"><div class="user-avatar" style="width:28px;height:28px;font-size:12px;"><%= u.name[0].toUpperCase() %></div><%= u.name %></div></td>
          <td style="font-size:13px;color:var(--text-2);"><%= u.email %></td>
          <td><span class="badge" style="background:<%= {admin:'#EEF1FE',ci:'#FEF3C7',viewer:'#F1F5F9'}[u.role] %>;color:<%= {admin:'#4F6EF7',ci:'#D97706',viewer:'#64748B'}[u.role] %>;"><%= u.role %></span></td>
          <td><span style="font-size:12px;font-weight:600;color:<%= u.is_active?'#22C55E':'#EF4444' %>;">● <%= u.is_active?'Active':'Suspended' %></span></td>
          <td style="font-size:12px;color:var(--text-3);"><%= new Date(u.created_at).toLocaleDateString() %></td>
          <td>
            <% if (u.role !== 'admin' && u.id !== user.id) { %>
            <form method="POST" action="/admin/users/<%= u.id %>/toggle" style="display:inline;">
              <button class="btn btn-ghost btn-sm" style="color:<%= u.is_active?'var(--danger)':'#22C55E' %>;" onclick="return confirm('<%= u.is_active?'Suspend':'Reactivate' %> <%= u.name %>?')">
                <%- icon(u.is_active ? 'user-x' : 'user-check') %> <%= u.is_active?'Suspend':'Reactivate' %>
              </button>
            </form>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../layouts/app_footer') %>
