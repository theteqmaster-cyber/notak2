<%- include('layouts/app_header', { title }) %>
<% if (!semesters.length) { %>
<div class="empty-state"><%- icon('archive') %><h3>No archived semesters</h3><p>Semesters appear here once archived.</p></div>
<% } else { %>
<div style="display:flex;flex-direction:column;gap:20px;">
  <% semesters.forEach(s => { %>
  <div class="card">
    <div class="card-header">
      <div><span class="card-title"><%= s.name %></span> <span class="badge badge-archived" style="margin-left:8px;">Archived</span></div>
      <% if (s.end_date) { %><span style="font-size:12px;color:var(--text-3);">Ended <%= new Date(s.end_date).toLocaleDateString() %></span><% } %>
    </div>
    <div class="card-body">
      <% const validCourses = (s.courses||[]).filter(c=>c); %>
      <% if (validCourses.length) { %>
      <div class="course-grid">
        <% validCourses.forEach(c => { %>
        <a href="/course/<%= c.id %>" class="course-card" style="padding:12px 14px;">
          <div class="course-dot" style="background:<%= c.color||'#4F6EF7' %>"></div>
          <div class="course-name" style="font-size:13px;"><%= c.name %></div>
        </a>
        <% }) %>
      </div>
      <% } else { %>
      <p style="color:var(--text-3);font-size:13px;">No courses.</p>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>
<% } %>
<%- include('layouts/app_footer') %>
