<% const body = `
<h2>Welcome back</h2>
<p style="color:var(--text-3);margin-bottom:24px;">Sign in to your Notak2 account</p>

<% if (error) { %>
<div class="flash flash-error"><%- icon('circle-x') %> <%= error %></div>
<% } %>

<form method="POST" action="/login">
  <div class="form-group">
    <label class="form-label">Email address</label>
    <input type="email" name="email" class="form-control" placeholder="you@example.com" required autofocus>
  </div>
  <div class="form-group">
    <label class="form-label">Password</label>
    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
  </div>
  <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:8px;">Sign in</button>
</form>
<p style="text-align:center;margin-top:20px;font-size:13px;color:var(--text-3);">
  No account? <a href="/register" style="color:var(--primary);font-weight:600;">Create one</a>
</p>
`; %>
<%- include('../layouts/auth', { body }) %>
