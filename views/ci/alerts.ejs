<%- include('../layouts/app', { title, body: `
<div class="page-header"><h1 style="color:var(--danger);">Security Alerts</h1></div>
<% if (!logs.length) { %>
<div class="empty-state"><%- icon('shield') %><h3>No flagged events</h3><p>All clear — no suspicious activity detected.</p></div>
<% } else { %>
<div class="card">
  <div class="table-wrap"><table>
    <thead><tr><th>Event</th><th>User</th><th>IP</th><th>Description</th><th>Time</th></tr></thead>
    <tbody>
      <% logs.forEach(log => { %>
      <tr class="log-flagged">
        <td style="font-weight:700;font-size:13px;color:var(--danger);"><%= log.event_type %></td>
        <td style="font-size:12px;"><%= log.user_email||'Guest' %></td>
        <td style="font-size:12px;font-family:monospace;"><%= log.ip_address||'—' %></td>
        <td style="font-size:12px;"><%= log.description||'' %></td>
        <td style="font-size:11px;color:var(--text-3);white-space:nowrap;"><%= new Date(log.created_at).toLocaleString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table></div>
</div>
<% } %>
` }) %>
