<%- include('../layouts/app_header', { title }) %>
<div class="stats-grid" style="margin-bottom:24px;">
  <% [
    {label:'Logins Today',value:stats.logins_today,icon:'users',color:'#22C55E',bg:'#DCFCE7'},
    {label:'Failed Logins',value:stats.failed_today,icon:'triangle-alert',color:'#EF4444',bg:'#FEE2E2'},
    {label:'Flagged Events',value:stats.flagged_total,icon:'flag',color:'#F59E0B',bg:'#FEF3C7'},
    {label:'Uploads Today',value:stats.uploads_today,icon:'upload',color:'#4F6EF7',bg:'#EEF1FE'},
    {label:'Total Users',value:stats.total_users,icon:'users',color:'#8B5CF6',bg:'#EDE9FE'},
  ].forEach(s => { %>
  <div class="stat-card">
    <div class="stat-icon" style="background:<%= s.bg %>;color:<%= s.color %>;"><%- icon(s.icon) %></div>
    <div class="stat-value"><%= s.value||0 %></div>
    <div class="stat-label"><%= s.label %></div>
  </div>
  <% }) %>
</div>
<div style="display:flex;gap:10px;margin-bottom:24px;">
  <a href="/ci/logs" class="btn btn-secondary"><%- icon('scroll-text') %> All Logs</a>
  <a href="/ci/alerts" class="btn btn-danger"><%- icon('flag') %> Alerts</a>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
  <div class="card">
    <div class="card-header"><span class="card-title">Recent Activity</span></div>
    <div class="table-wrap"><table>
      <thead><tr><th>Event</th><th>User</th><th>When</th></tr></thead>
      <tbody>
        <% recent.forEach(log => { %>
        <tr class="<%= log.is_flagged?'log-flagged':'' %>">
          <td style="font-size:13px;"><%= log.event_type %></td>
          <td style="font-size:12px;"><%= log.user_email||'Guest' %></td>
          <td style="font-size:11px;color:var(--text-3);"><%= new Date(log.created_at).toLocaleString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table></div>
  </div>
  <div class="card">
    <div class="card-header"><span class="card-title" style="color:var(--danger);">⚠ Flagged</span></div>
    <div class="table-wrap"><table>
      <thead><tr><th>Event</th><th>IP</th><th>When</th></tr></thead>
      <tbody>
        <% if (!flagged.length) { %>
        <tr><td colspan="3" style="text-align:center;padding:24px;color:var(--accent);font-weight:600;">All clear</td></tr>
        <% } else { flagged.forEach(log => { %>
        <tr class="log-flagged">
          <td style="font-weight:600;font-size:13px;"><%= log.event_type %></td>
          <td style="font-size:12px;font-family:monospace;"><%= log.ip_address||'—' %></td>
          <td style="font-size:11px;color:var(--text-3);"><%= new Date(log.created_at).toLocaleString() %></td>
        </tr>
        <% }) } %>
      </tbody>
    </table></div>
  </div>
</div>
<%- include('../layouts/app_footer') %>
