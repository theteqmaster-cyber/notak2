<%- include('../layouts/app_header', { title }) %>
<div class="page-header"><h1>Activity Logs</h1></div>
<form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;align-items:flex-end;">
  <div class="form-group" style="margin:0;"><label class="form-label">Event Type</label><input type="text" name="type" class="form-control" placeholder="e.g. login" value="<%= filters.type||'' %>"></div>
  <div class="form-group" style="margin:0;"><label class="form-label">Date</label><input type="date" name="date" class="form-control" value="<%= filters.date||'' %>"></div>
  <div class="form-group" style="margin:0;padding-top:22px;"><label style="display:flex;align-items:center;gap:6px;cursor:pointer;"><input type="checkbox" name="flagged" value="1" <%= filters.flagged?'checked':'' %>><span>Flagged only</span></label></div>
  <button type="submit" class="btn btn-primary btn-sm">Filter</button>
  <a href="/ci/logs" class="btn btn-ghost btn-sm">Clear</a>
</form>
<div class="card">
  <div class="table-wrap"><table>
    <thead><tr><th>Event</th><th>User</th><th>IP</th><th>Description</th><th>Time</th></tr></thead>
    <tbody>
      <% logs.forEach(log => { %>
      <tr class="<%= log.is_flagged?'log-flagged':'' %>">
        <td style="font-weight:600;font-size:13px;"><%= log.event_type %></td>
        <td style="font-size:12px;"><%= log.user_email||'Guest' %></td>
        <td style="font-size:12px;font-family:monospace;"><%= log.ip_address||'—' %></td>
        <td style="font-size:12px;color:var(--text-2);"><%= log.description||'' %></td>
        <td style="font-size:11px;color:var(--text-3);white-space:nowrap;"><%= new Date(log.created_at).toLocaleString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table></div>
</div>
<%- include('../layouts/app_footer') %>
