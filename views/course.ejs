<%- include('layouts/app', { title, body: `
<div class="page-header">
  <div><h1><%= course.name %></h1><p><%= course.semester_name %><% if (course.code) { %> · <%= course.code %><% } %></p></div>
</div>
<div class="tab-bar">
  <% [['N','Notes'],['A','Assignments'],['P','Presentations'],['T','Tests'],['S','Sources']].forEach(([t,label]) => { %>
  <a href="/course/<%= course.id %>?type=<%= t %>" class="tab <%= activeType===t?'active':'' %>">
    <%- icon(TYPE_ICONS[t]) %> <%= label %> <span class="tab-count"><%= counts[t]||0 %></span>
  </a>
  <% }) %>
</div>
<% if (items.length) { %>
<div class="card">
  <div class="item-list">
    <% items.forEach(item => { %>
    <div class="item-row type-<%= item.type %>">
      <div class="item-icon"><%- icon(TYPE_ICONS[item.type]) %></div>
      <div class="item-info">
        <a href="/item/<%= item.id %>" class="item-title" style="text-decoration:none;color:inherit;"><%= item.title %></a>
        <div class="item-meta">
          <% if (item.file_size) { %><span><%= (item.file_size/1048576).toFixed(1) %> MB</span><% } %>
          <span><%= new Date(item.created_at).toLocaleDateString() %></span>
          <span><%= item.download_count %> downloads</span>
        </div>
      </div>
      <div class="item-actions">
        <a href="/item/<%= item.id %>" class="btn btn-ghost btn-sm"><%- icon('eye') %></a>
        <a href="/item/<%= item.id %>/download" class="btn btn-ghost btn-sm"><%- icon('download') %></a>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } else { %>
<div class="empty-state"><%- icon(TYPE_ICONS[activeType]) %><h3>No <%= TYPE_LABELS[activeType] %> yet</h3><p>Check back later.</p></div>
<% } %>
` }) %>
