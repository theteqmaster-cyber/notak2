<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Notak2</title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>

<div id="app-layout">
  <!-- Sidebar -->
  <aside id="sidebar" class="sidebar">
    <div class="sidebar-header">
      <a href="/" class="sidebar-brand">
        <div class="brand-icon">N2</div>
        <span class="brand-name">Notak<span class="brand-accent">2</span></span>
      </a>
    </div>

    <nav class="sidebar-nav">
      <% if (user && user.role === 'viewer') { %>
        <a href="/dashboard" class="nav-link <%= path === '/dashboard' ? 'active' : '' %>"><%- icon('layout-dashboard') %> Dashboard</a>
        <a href="/archives"  class="nav-link <%= path.startsWith('/archives') ? 'active' : '' %>"><%- icon('archive') %> Archives</a>
      <% } %>

      <% if (user && user.role === 'admin') { %>
        <div class="nav-label">Content</div>
        <a href="/admin"         class="nav-link <%= path === '/admin' ? 'active' : '' %>"><%- icon('layout-dashboard') %> Dashboard</a>
        <a href="/admin/upload"  class="nav-link <%= path === '/admin/upload' ? 'active' : '' %>"><%- icon('upload') %> Upload</a>
        <a href="/admin/items"   class="nav-link <%= path.startsWith('/admin/items') ? 'active' : '' %>"><%- icon('files') %> All Items</a>
        <div class="nav-label">Manage</div>
        <a href="/admin/semesters" class="nav-link <%= path.startsWith('/admin/semesters') ? 'active' : '' %>"><%- icon('calendar') %> Semesters</a>
        <a href="/admin/courses"   class="nav-link <%= path.startsWith('/admin/courses') ? 'active' : '' %>"><%- icon('book') %> Courses</a>
        <a href="/admin/users"     class="nav-link <%= path.startsWith('/admin/users') ? 'active' : '' %>"><%- icon('users') %> Users</a>
      <% } %>

      <% if (user && user.role === 'ci') { %>
        <div class="nav-label">Monitoring</div>
        <a href="/ci"        class="nav-link <%= path === '/ci' ? 'active' : '' %>"><%- icon('shield') %> CI Dashboard</a>
        <a href="/ci/logs"   class="nav-link <%= path === '/ci/logs' ? 'active' : '' %>"><%- icon('scroll-text') %> Activity Logs</a>
        <a href="/ci/alerts" class="nav-link <%= path === '/ci/alerts' ? 'active' : '' %>"><%- icon('triangle-alert') %> Alerts</a>
      <% } %>
    </nav>

    <div class="sidebar-footer">
      <% if (user) { %>
        <div class="user-avatar"><%= user.name[0].toUpperCase() %></div>
        <div class="user-info">
          <div class="user-name"><%= user.name %></div>
          <div class="user-role"><%= user.role %></div>
        </div>
        <form method="POST" action="/logout" style="margin:0;">
          <button type="submit" class="btn-logout" title="Sign out"><%- icon('log-out') %></button>
        </form>
      <% } %>
    </div>
  </aside>

  <!-- Main -->
  <main class="main-content">
    <header class="topbar">
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar"><%- icon('menu') %></button>
      <div class="topbar-title"><%= title %></div>
      <div class="topbar-actions"><%- typeof topbarActions !== 'undefined' ? topbarActions : '' %></div>
    </header>

    <% if (flash) { %>
      <div style="padding:0 24px;margin-top:16px;">
        <div class="flash flash-<%= flash.type %>">
          <%- icon(flash.type === 'success' ? 'circle-check' : 'circle-x') %> <%= flash.message %>
        </div>
      </div>
    <% } %>

    <div class="page-body">
      <%- body %>
    </div>
  </main>
</div>

<div id="sidebar-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:99;"></div>
<script src="/js/app.js"></script>
</body>
</html>
